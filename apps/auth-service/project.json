{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "auth-service",
  "projectType": "application",
  "root": "apps/auth-service",
  "sourceRoot": "apps/auth-service/src",
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node -r ts-node/register -r tsconfig-paths/register src/main.ts",
        "cwd": "apps/auth-service",
        "env": {
          "PORT": "3003"
        }
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p tsconfig.build.json",
        "cwd": "apps/auth-service"
      }
    },
    "export-swagger": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node -r ts-node/register -r tsconfig-paths/register src/export-swagger.ts",
        "cwd": "apps/auth-service"
      }
    },
    "publish-contract": {
      "executor": "nx:run-commands",
      "dependsOn": ["export-swagger"],
      "options": {
        "command": "node tools/contracts/publish-contract.mjs auth-service"
      }
    }
  },
  "tags": []
}
