{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "users-service",
  "projectType": "application",
  "root": "apps/users-service",
  "sourceRoot": "apps/users-service/src",
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node -r ts-node/register -r tsconfig-paths/register src/main.ts",
        "cwd": "apps/users-service",
        "env": {
          "PORT": "3001"
        }
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p tsconfig.build.json",
        "cwd": "apps/users-service"
      }
    },
    "export-swagger": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node -r ts-node/register -r tsconfig-paths/register src/export-swagger.ts",
        "cwd": "apps/users-service"
      }
    }
  },
  "tags": []
}
