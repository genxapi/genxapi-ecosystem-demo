{
  "name": "genxapi-ecosystem-demo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "nx": "nx",
    "serve:users-service": "nx serve users-service",
    "serve:payments-service": "nx serve payments-service",
    "serve:web-app": "nx serve web-app",
    "serve:backoffice-app": "nx serve backoffice-app",
    "serve:mobile-app": "nx serve mobile-app",
    "swagger:pull": "node tools/swagger/pull-swagger.mjs",
    "swagger:export:payments": "node -r ts-node/register -r tsconfig-paths/register apps/payments-service/src/export-swagger.ts",
    "swagger:export:users": "nx run users-service:export-swagger",
    "pregen:sdk:users": "npm run swagger:export:users",
    "gen:sdk:payments": "npx genxapi generate --log-level info",
    "gen:sdk:users": "npx genxapi generate --config genxapi.users.config.json --log-level info",
    "graph": "nx graph"
  },
  "dependencies": {
    "@genxapi/ecosystem-users-sdk": "0.1.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.0.0",
    "@tanstack/react-query": "^5.65.1",
    "@tanstack/react-query-devtools": "^5.65.1",
    "genxapi-ecosystem-payments-sdk": "0.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "@genxapi/cli": "latest",
    "@genxapi/template-orval": "latest",
    "@nx/workspace": "latest",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "nx": "latest",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.0",
    "vite": "^5.0.0"
  }
}
