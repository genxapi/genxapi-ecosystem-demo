{
  "openapi": "3.0.0",
  "paths": {
    "/health": {
      "get": {
        "operationId": "HealthController_getHealth",
        "summary": "Payments service health check",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthCheckResponse"
                }
              }
            }
          }
        }
      }
    },
    "/me/payments": {
      "get": {
        "operationId": "PaymentsController_getMyPayments",
        "summary": "Return the authenticated user payments",
        "description": "Customer self-service route. The service resolves ownership from the JWT sub claim instead of trusting caller-supplied user ids.",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Payments owned by the authenticated subject.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Payment"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid bearer token."
          }
        },
        "tags": [
          "Payments"
        ],
        "security": [
          {
            "bearer": []
          }
        ]
      }
    },
    "/payments": {
      "get": {
        "operationId": "PaymentsController_getPayments",
        "summary": "Return the internal payments list",
        "description": "Read-only internal route for support and admin personas.",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Internal payments list.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Payment"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid bearer token."
          },
          "403": {
            "description": "Requires support or admin role."
          }
        },
        "tags": [
          "Payments"
        ],
        "security": [
          {
            "bearer": []
          }
        ]
      }
    },
    "/payments/{paymentId}": {
      "get": {
        "operationId": "PaymentsController_getPayment",
        "summary": "Return an internal payment by paymentId",
        "description": "Read-only internal route for support and admin personas. The route identifies a payment resource by paymentId; it is not a user-payment shortcut.",
        "parameters": [
          {
            "name": "paymentId",
            "required": true,
            "in": "path",
            "description": "Payment ID to retrieve",
            "schema": {
              "example": 1001,
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Requested payment resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Payment"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid bearer token."
          },
          "403": {
            "description": "Requires support or admin role."
          },
          "404": {
            "description": "Payment was not found."
          }
        },
        "tags": [
          "Payments"
        ],
        "security": [
          {
            "bearer": []
          }
        ]
      }
    },
    "/users/{userId}/payments": {
      "get": {
        "operationId": "PaymentsController_getUserPayments",
        "summary": "Return internal payments for a specific userId",
        "description": "Read-only internal convenience route for support and admin personas. It filters payment resources by owning userId.",
        "parameters": [
          {
            "name": "userId",
            "required": true,
            "in": "path",
            "description": "User ID to filter payments by",
            "schema": {
              "example": 1,
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Payments owned by the requested userId. Returns an empty array when that user has no payments.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Payment"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid bearer token."
          },
          "403": {
            "description": "Requires support or admin role."
          }
        },
        "tags": [
          "Payments"
        ],
        "security": [
          {
            "bearer": []
          }
        ]
      }
    }
  },
  "info": {
    "title": "Payments Service",
    "description": "Payments service API for the genxapi ecosystem demo. Protected routes use a demo HS256 bearer JWT. customer can read only /me/payments. support and admin can read internal /payments routes and user payment lookups.",
    "version": "0.4.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http",
        "description": "Demo HS256 bearer token. Required claims: sub (numeric user id), role (customer|support|admin), email, name, iss, aud."
      }
    },
    "schemas": {
      "HealthCheckResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "ok",
            "description": "Service status",
            "enum": [
              "ok"
            ]
          },
          "service": {
            "type": "string",
            "example": "payments-service",
            "description": "Service name",
            "enum": [
              "payments-service"
            ]
          }
        },
        "required": [
          "status",
          "service"
        ]
      },
      "Payment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "example": 1001,
            "description": "Unique payment identifier"
          },
          "userId": {
            "type": "number",
            "example": 1,
            "description": "Foreign key referencing the user"
          },
          "amount": {
            "type": "number",
            "example": 199.99,
            "description": "Payment amount"
          },
          "currency": {
            "type": "string",
            "example": "USD",
            "description": "ISO currency code"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "completed",
              "failed",
              "refunded"
            ],
            "example": "completed"
          },
          "method": {
            "type": "string",
            "enum": [
              "credit_card",
              "paypal",
              "bank_transfer",
              "stripe"
            ],
            "example": "credit_card"
          },
          "transactionId": {
            "type": "string",
            "example": "txn_8f3a21c9",
            "description": "External transaction reference"
          },
          "createdAt": {
            "type": "string",
            "example": "2025-02-01T10:15:00Z",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "userId",
          "amount",
          "currency",
          "status",
          "method",
          "transactionId",
          "createdAt"
        ]
      }
    }
  }
}
