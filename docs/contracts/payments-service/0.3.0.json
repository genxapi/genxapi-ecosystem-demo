{
  "openapi": "3.0.0",
  "paths": {
    "/health": {
      "get": {
        "operationId": "HealthController_getHealth",
        "summary": "Payments service health check",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthCheckResponse"
                }
              }
            }
          }
        }
      }
    },
    "/me/payments": {
      "get": {
        "operationId": "PaymentsController_getMyPayments",
        "summary": "Return the authenticated user payments",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Payment"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid bearer token."
          },
          "403": {
            "description": "Authenticated user does not have access to this route."
          }
        },
        "tags": [
          "Payments"
        ],
        "security": [
          {
            "bearer": []
          }
        ]
      }
    },
    "/payments": {
      "get": {
        "operationId": "PaymentsController_getPayments",
        "summary": "Return a list of payments for internal support and admin tooling",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Payment"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid bearer token."
          },
          "403": {
            "description": "Authenticated user does not have access to this route."
          }
        },
        "tags": [
          "Payments"
        ],
        "security": [
          {
            "bearer": []
          }
        ]
      }
    },
    "/payments/{paymentId}": {
      "get": {
        "operationId": "PaymentsController_getPayment",
        "summary": "Return details of a specific payment for internal support and admin tooling",
        "parameters": [
          {
            "name": "paymentId",
            "required": true,
            "in": "path",
            "description": "Payment ID to retrieve",
            "schema": {
              "example": 1001,
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Payment"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid bearer token."
          },
          "403": {
            "description": "Authenticated user does not have access to this route."
          },
          "404": {
            "description": "Payment was not found."
          }
        },
        "tags": [
          "Payments"
        ],
        "security": [
          {
            "bearer": []
          }
        ]
      }
    },
    "/users/{userId}/payments": {
      "get": {
        "operationId": "PaymentsController_getUserPayments",
        "summary": "Return payments for a specific user for internal support and admin tooling",
        "parameters": [
          {
            "name": "userId",
            "required": true,
            "in": "path",
            "description": "User ID to filter payments by",
            "schema": {
              "example": 1,
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Payment"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid bearer token."
          },
          "403": {
            "description": "Authenticated user does not have access to this route."
          }
        },
        "tags": [
          "Payments"
        ],
        "security": [
          {
            "bearer": []
          }
        ]
      }
    }
  },
  "info": {
    "title": "Payments Service",
    "description": "Payments service API for the genxapi ecosystem demo",
    "version": "0.3.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http",
        "description": "Demo HS256 bearer token. Required claims: sub (user id), role, email, name, iss, aud."
      }
    },
    "schemas": {
      "HealthCheckResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "ok",
            "description": "Service status",
            "enum": [
              "ok"
            ]
          },
          "service": {
            "type": "string",
            "example": "payments-service",
            "description": "Service name",
            "enum": [
              "payments-service"
            ]
          }
        },
        "required": [
          "status",
          "service"
        ]
      },
      "Payment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "example": 1001,
            "description": "Unique payment identifier"
          },
          "userId": {
            "type": "number",
            "example": 1,
            "description": "Foreign key referencing the user"
          },
          "amount": {
            "type": "number",
            "example": 199.99,
            "description": "Payment amount"
          },
          "currency": {
            "type": "string",
            "example": "USD",
            "description": "ISO currency code"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "completed",
              "failed",
              "refunded"
            ],
            "example": "completed"
          },
          "method": {
            "type": "string",
            "enum": [
              "credit_card",
              "paypal",
              "bank_transfer",
              "stripe"
            ],
            "example": "credit_card"
          },
          "transactionId": {
            "type": "string",
            "example": "txn_8f3a21c9",
            "description": "External transaction reference"
          },
          "createdAt": {
            "type": "string",
            "example": "2025-02-01T10:15:00Z",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "userId",
          "amount",
          "currency",
          "status",
          "method",
          "transactionId",
          "createdAt"
        ]
      }
    }
  }
}
