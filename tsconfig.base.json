{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "baseUrl": ".",
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "node",
    "sourceMap": true,
    "declaration": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "importHelpers": false,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "paths": {
      "@genxapi/ecosystem-users-sdk": ["sdk/users-sdk/src/index.ts"],
      "@genxapi/ecosystem-users-sdk/*": ["sdk/users-sdk/src/*"],
      "genxapi-ecosystem-payments-sdk": ["sdk/payments-sdk/src/index.ts"],
      "genxapi-ecosystem-payments-sdk/*": ["sdk/payments-sdk/src/*"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
