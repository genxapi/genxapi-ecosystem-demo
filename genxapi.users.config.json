{
  "$schema": "https://raw.githubusercontent.com/genxapi/genxapi/main/packages/cli/schemas/genxapi.schema.json",
  "logLevel": "info",
  "project": {
    "name": "@genxapi-labs/ecosystem-users-sdk",
    "directory": "./sdk/users-sdk",
    "template": "orval",
    "output": "./src",
    "config": {
      "httpClient": "fetch",
      "client": "fetch",
      "mode": "split",
      "mock": {
        "type": "off"
      }
    },
    "publish": {
      "npm": {
        "enabled": false
      }
    }
  },
  "clients": [
    {
      "name": "users",
      "swagger": "./docs/contracts/users-service/latest.json",
      "copySwagger": false,
      "config": {
        "baseUrl": ""
      }
    }
  ]
}
