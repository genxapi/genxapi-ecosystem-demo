{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "npmScope": "genxapi",
  "affected": {
    "defaultBase": "main"
  },
  "workspaceLayout": {
    "appsDir": "apps",
    "libsDir": "libs"
  },
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "sharedGlobals": ["{workspaceRoot}/package.json", "{workspaceRoot}/tsconfig.base.json"]
  },
  "targetDefaults": {
    "build": {
      "inputs": ["default", "^default"]
    },
    "serve": {
      "inputs": ["default", "^default"]
    }
  }
}
